        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "content": {
                    "type": "string"
                  },
                  "videoUrl": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lesson updated successfully"
          },
          "403": {
            "description": "Forbidden - admin only"
          },
          "404": {
            "description": "Lesson not found"
          }
        }
      },
      "delete": {
        "tags": ["Lessons"],
        "summary": "Delete lesson",
        "description": "Delete a lesson (admin only)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "lessonId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lesson deleted successfully"
          },
          "403": {
