        }
      }
    },
    "/api/progress": {
      "get": {
        "tags": ["Progress"],
        "summary": "Get user progress",
        "description": "Retrieve the current user's progress across courses",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User progress retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserProgress"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/progress/lesson/{lessonId}": {
      "post": {
        "tags": ["Progress"],
        "summary": "Mark lesson as complete",
        "description": "Mark a lesson as completed for the current user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "lessonId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Progress updated successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Lesson not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Course": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "course_123"
          },
          "title": {
            "type": "string",
            "example": "Introduction to React"
          },
          "description": {
            "type": "string",
            "example": "Learn the basics of React"
          },
          "thumbnail": {
            "type": "string"
          },
          "instructor": {
            "type": "string"
          },
          "lessonCount": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Lesson": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "lesson_123"
          },
          "courseId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "videoUrl": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserProgress": {
        "type": "object",
        "properties": {
          "courseId": {
            "type": "string"
          },
          "courseName": {
            "type": "string"
          },
          "completedLessons": {
            "type": "integer"
          },
          "totalLessons": {
            "type": "integer"
          },
          "progressPercentage": {
            "type": "number",
            "format": "float"
          },
          "lastAccessedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT authentication token"
      }
    }
  }
}
