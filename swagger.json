                  "$ref": "#/components/schemas/Lesson"
                }
              }
            }
          },
          "404": {
            "description": "Lesson not found"
          }
        }
      },
      "put": {
        "tags": ["Lessons"],
        "summary": "Update lesson",
        "description": "Update a lesson (admin only)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "lessonId",
